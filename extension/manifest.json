{
  "manifest_version": 3,
  "name": "Sheltermark",
  "version": "1.0.0",
  "description": "Save any page or link to your Sheltermark bookmarks with one click.",
  "permissions": [
    "activeTab",
    "storage",
    "tabs",
    "contextMenus",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://sheltermark.vercel.app/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "externally_connectable": {
    "matches": ["https://sheltermark.vercel.app/*"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://www.x.com/*",
        "https://twitter.com/*",
        "https://www.twitter.com/*"
      ],
      "js": ["dist/x-capture.js"],
      "run_at": "document_end"
    }
  ],
  "commands": {
    "save-current-tab": {
      "suggested_key": {
        "default": "Ctrl+Shift+K",
        "mac": "Command+Shift+K"
      },
      "description": "Save current tab to Sheltermark"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
